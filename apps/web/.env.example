APP_NAME="Monitoring SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

UID=1000
GID=1000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=monitoring
DB_USERNAME=monitoring
DB_PASSWORD=monitoring_secret

POSTGRES_DB=monitoring
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=monitoring_secret
POSTGRES_PORT=5432

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=monitoring
RABBITMQ_PASSWORD=monitoring_secret
RABBITMQ_VHOST=monitoring
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_TASKS_EXCHANGE=checks.tasks
RABBITMQ_RESULTS_EXCHANGE=checks.results
RABBITMQ_RESULTS_QUEUE=checks.results

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME="Monitoring SaaS"

GOOGLE_AUTH_ENABLED=false
REGISTRATION_EMAIL_VERIFICATION_ENABLED=false

POLLER_MODE=service
POLLER_PORT=8090
POLLER_HTTP_ADDR=:8090
POLLER_WORKERS=10
POLLER_CHECK_TIMEOUT_SECONDS=10
POLLER_QUEUE_BUFFER=100
POLLER_SHUTDOWN_TIMEOUT=10s
POLLER_SCHEDULER_INTERVAL_SECONDS=30
POLLER_FETCH_DUE_LIMIT=100

LARAVEL_INTERNAL_API_URL=http://nginx
LARAVEL_INTERNAL_API_TOKEN=
LARAVEL_INTERNAL_API_TIMEOUT_SECONDS=10

POLLER_RESULT_RETRY_ATTEMPTS=3
POLLER_RESULT_RETRY_DELAY_SECONDS=1

POLLER_TOKEN=
POLLER_MANUAL_API_TOKEN=
POLLER_MANUAL_REQUEST_TIMEOUT_SECONDS=5

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

LOKI_PORT=3100
TEMPO_PORT=3200
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318
OTEL_GRPC_PORT=4319
OTEL_HTTP_PORT=4320
OTEL_FLUENT_FORWARD_PORT=8006
OTEL_METRICS_PORT=8888
OTEL_PROMETHEUS_EXPORTER_PORT=8889
OTEL_TRACES_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_POLLER_SERVICE_NAME=montry-poller

SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_LARAVEL_DSN=
SENTRY_POLLER_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=
