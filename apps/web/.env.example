CLICKHOUSE_DB=montry_analytics
CLICKHOUSE_USER=montry
CLICKHOUSE_PASSWORD=montry_secret
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_TIMEOUT_SECONDS=5

NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8088
BLACKBOX_EXPORTER_PORT=9115

POSTGRES_SERVICE=postgres
POSTGRES_BACKUP_DIR=backups/postgres
POSTGRES_BACKUP_RETENTION_DAYS=14
BACKUP_METRICS_DIR=docker/observability/node-exporter/textfile_collector

OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_TOKEN=
