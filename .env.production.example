# Root Docker Compose environment only.
# Copy to .env.production and do not place Laravel or poller application settings here.

APP_PORT=80
APP_UID=1000
APP_GID=1000

WEB_ENV_FILE=./apps/web/.env.production
POLLER_ENV_FILE=./apps/poller/.env.production

POSTGRES_DB=montry
POSTGRES_USER=montry
POSTGRES_PASSWORD=change-me
